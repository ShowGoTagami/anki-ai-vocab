# ===== AI (text generation) provider =====
# Choose which AI generates vocabulary info: "openai" (default) or "gemini"
AI_PROVIDER=openai

# OpenAI API Configuration (used when AI_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key-here
# Optional: override the OpenAI model (default: gpt-4.1-mini)
# OPENAI_MODEL=gpt-4.1-mini

# Google Gemini API Configuration (used when AI_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key-here
# Optional: override the Gemini model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# ===== TTS (audio generation) provider =====
# Choose which engine generates audio: "polly" (default) or "elevenlabs"
TTS_PROVIDER=polly

# AWS Configuration (used when TTS_PROVIDER=polly)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1

# ElevenLabs Configuration (used when TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
# Optional: default ElevenLabs voice id (default: 21m00Tcm4TlvDq8ikWAM / "Rachel")
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Optional: ElevenLabs model id (default: eleven_multilingual_v2)
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Anki Configuration
ANKI_HOST=host.docker.internal
ANKI_PORT=8765
DECK_NAME=English Vocabulary
MODEL_NAME=Basic (and reversed card)
